# ===========================================
# FreightLink Africa Production Environment
# For Render Deployment
# ===========================================

# Application
NODE_ENV=production
PORT=5000
APP_NAME=FreightLink Africa
API_VERSION=v1
FRONTEND_URL=https://your-frontend.onrender.com

# Database - Supabase PostgreSQL
# Get these from Supabase Dashboard > Settings > Database
DB_HOST=your-project-ref.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-supabase-db-password
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000

# Redis - Render Redis Instance
# Automatically linked via render.yaml
REDIS_HOST=your-redis-host.render.com
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Authentication
# Use 'generateValue: true' in render.yaml or set manually
JWT_SECRET=your-32-char-minimum-secret-key-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-32-char-minimum-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=freightlink.africa

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-api.onrender.com/api/v1/auth/google/callback

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_RETRIES=3

# Paynow Payment Gateway
PAYNOW_INTEGRATION_ID=your-integration-id
PAYNOW_INTEGRATION_KEY=your-integration-key
PAYNOW_RESULT_URL=https://your-api.onrender.com/api/v1/webhooks/paynow/result
PAYNOW_RETURN_URL=https://your-frontend.onrender.com/payment/complete
PAYNOW_SANDBOX=false

# WhatsApp Business API
WHATSAPP_API_VERSION=v18.0
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-verify-token
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
CORS_ORIGINS=https://your-frontend.onrender.com

# File Uploads
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM=noreply@freightlink.africa

# Pricing
BASE_UNLOCK_PRICE=2.00
WHATSAPP_CONVERSATION_COST=0.04
GEMINI_COST_PER_REQUEST=0.001
PAYNOW_FEE_PERCENT=3.5
INFRASTRUCTURE_ALLOCATION=0.10
EXPECTED_CONVERSION_RATE=0.10

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
