# ===========================================
# FreightLink Africa Production Environment
# ===========================================

# Application
NODE_ENV=production
FRONTEND_URL=https://your-domain.com
BACKEND_PORT=5000
FRONTEND_PORT=80

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=freightlink
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT (generate strong secrets)
JWT_SECRET=CHANGE_ME_32CHAR_RANDOM_STRING_FOR_JWT
JWT_REFRESH_SECRET=CHANGE_ME_32CHAR_RANDOM_STRING_FOR_REFRESH
JWT_ISSUER=freightlink.africa

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.com/api/v1/auth/google/callback

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Paynow
PAYNOW_INTEGRATION_ID=your-integration-id
PAYNOW_INTEGRATION_KEY=your-integration-key
PAYNOW_RESULT_URL=https://your-domain.com/api/v1/webhooks/paynow/result
PAYNOW_RETURN_URL=https://your-domain.com/payment/complete
PAYNOW_SANDBOX=false

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-verify-token
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
